{
	"name": "publishio",
	"private": true,
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"files": [
		"assets",
		"build",
		"build-apps",
		"framework",
		"inc",
		"languages",
		"skills",
		"templates",
		"vendor",
		"composer.json",
		"README.md",
		"readme.txt",
		"publishio.php",
		"uninstall.php"
	],
	"scripts": {
		"build": "npm run clean && npm-run-all build:*",
		"build:admin": "cross-env NODE_ENV=production wp-scripts build",
		"build:apps": "cross-env NODE_ENV=production WP_NO_EXTERNALS=true wp-scripts build --config webpack.apps.config.js",
		"clean": "rimraf build build-apps",
		"format": "wp-scripts format",
		"i18n:make-pot": "wp-env run cli --env-cwd=wp-content/plugins/publishio/ -- wp i18n make-pot . ./languages/publishio.pot --domain=publishio --include='*.php,inc,framework,src,templates' --exclude='assets,build,build-apps,node_modules,tests,vendor'",
		"i18n:make-json": "wp-env run cli --env-cwd=wp-content/plugins/publishio/ -- wp i18n make-json languages/ --no-purge",
		"lint:css:fix": "wp-scripts lint-style --fix",
		"lint:css": "wp-scripts lint-style",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"lint:js:types": "tsc --noEmit",
		"lint:js": "wp-scripts lint-js",
		"lint:php:fix": "wp-env run cli --env-cwd=wp-content/plugins/publishio/ composer run-script format",
		"lint:phpstan": "wp-env run cli --env-cwd=wp-content/plugins/publishio/ composer run-script phpstan",
		"lint:php": "wp-env run cli --env-cwd=wp-content/plugins/publishio/ composer run-script lint",
		"lint": "npm-run-all --parallel lint:*",
		"lint:fix": "npm-run-all --parallel lint:*:fix",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "lefthook install",
		"start:admin": "cross-env NODE_ENV=development wp-scripts start",
		"start:apps": "cross-env NODE_ENV=development WP_NO_EXTERNALS=true wp-scripts start --config webpack.apps.config.js",
		"test:js": "wp-scripts test-unit-js --passWithNoTests",
		"test:js:watch": "wp-scripts test-unit-js --watch",
		"test:js:coverage": "wp-scripts test-unit-js --passWithNoTests --coverage",
		"test:php": "npm run wp-env:test -- run cli --env-cwd=wp-content/plugins/publishio/ vendor/bin/phpunit -c phpunit.xml.dist",
		"wp-env": "wp-env",
		"wp-env:cli": "wp-env run cli --env-cwd=wp-content/plugins/publishio/",
		"wp-env:test": "wp-env --config=.wp-env.test.json"
	},
	"dependencies": {
		"@modelcontextprotocol/ext-apps": "^1.7.2",
		"clsx": "^2.1.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^29.5.14",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@wordpress/api-fetch": "^7.46.0",
		"@wordpress/babel-preset-default": "^8.45.0",
		"@wordpress/components": "^33.1.0",
		"@wordpress/data": "^10.46.0",
		"@wordpress/dataviews": "^14.3.0",
		"@wordpress/element": "^6.46.0",
		"@wordpress/env": "^11.5.0",
		"@wordpress/eslint-plugin": "^25.1.0",
		"@wordpress/i18n": "^6.18.0",
		"@wordpress/icons": "^13.1.0",
		"@wordpress/notices": "^5.46.0",
		"@wordpress/prettier-config": "^4.45.0",
		"@wordpress/scripts": "^32.1.0",
		"@wordpress/stylelint-config": "^23.37.0",
		"cross-env": "^10.1.0",
		"eslint-plugin-jest": "^29.15.2",
		"html-webpack-plugin": "^5.6.7",
		"jest-watch-typeahead": "^2.2.2",
		"lefthook": "^2.1.6",
		"lint-staged": "^17.0.5",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.15",
		"postcss-loader": "^8.2.1",
		"prettier": "npm:wp-prettier@^3",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"webpack-dev-server": ">=5.2.1",
		"@wordpress/scripts": {
			"markdownlint-cli": {
				"minimatch": "^3.1.5"
			},
			"serialize-javascript": "^7.0.3"
		},
		"uuid": "^14.0.0",
		"ws": "^8.20.1"
	}
}
