{
	"name": "rtcamp-publish-with-ai",
	"private": true,
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"files": [
		"assets",
		"build",
		"framework",
		"inc",
		"languages",
		"templates",
		"vendor",
		"README.md",
		"readme.txt",
		"rtcamp-publish-with-ai.php",
		"uninstall.php"
	],
	"scripts": {
		"build:dev": "cross-env NODE_ENV=development npm run build:js",
		"build:js": "wp-scripts build",
		"build:prod": "npm run clean && cross-env NODE_ENV=production npm run build:js",
		"clean": "rimraf build",
		"format": "wp-scripts format",
		"i18n:make-pot": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ -- wp i18n make-pot . ./languages/rtcamp-publish-with-ai.pot --domain=rtcamp-publish-with-ai --include='*.php,inc,framework,src,templates' --exclude='assets,build,node_modules,tests,vendor'",
		"i18n:make-json": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ -- wp i18n make-json languages/ --no-purge",
		"lint:css:fix": "wp-scripts lint-style --fix",
		"lint:css": "wp-scripts lint-style",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"lint:js:types": "tsc --noEmit",
		"lint:js": "wp-scripts lint-js",
		"lint:php:fix": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ composer run-script format",
		"lint:phpstan": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ composer run-script phpstan",
		"lint:php": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ composer run-script lint",
		"lint": "npm-run-all --parallel lint:*",
		"lint:fix": "npm-run-all --parallel lint:*:fix",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "lefthook install",
		"start:js": "wp-scripts start",
		"test:e2e": "wp-scripts test-playwright",
		"test:js": "wp-scripts test-unit-js --passWithNoTests",
		"test:js:watch": "wp-scripts test-unit-js --watch",
		"test:js:coverage": "wp-scripts test-unit-js --passWithNoTests --coverage",
		"test:php": "npm run wp-env:test -- run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/ vendor/bin/phpunit -c phpunit.xml.dist",
		"wp-env": "wp-env",
		"wp-env:cli": "wp-env run cli --env-cwd=wp-content/plugins/rtcamp-publish-with-ai/",
		"wp-env:test": "wp-env --config=.wp-env.test.json"
	},
	"dependencies": {
		"@wordpress/block-editor": "^15.18.0",
		"@wordpress/blocks": "^15.18.0",
		"@wordpress/dom-ready": "^4.45.0",
		"@wordpress/i18n": "^6.18.0",
		"@wordpress/interactivity": "^6.45.0",
		"classnames": "^2.5.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^29.5.14",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@types/wordpress__block-editor": "^15.0.6",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@wordpress/api-fetch": "^7.46.0",
		"@wordpress/babel-preset-default": "^8.45.0",
		"@wordpress/components": "^33.1.0",
		"@wordpress/dataviews": "^14.3.0",
		"@wordpress/e2e-test-utils-playwright": "^1.45.0",
		"@wordpress/element": "^6.46.0",
		"@wordpress/env": "^11.5.0",
		"@wordpress/eslint-plugin": "^25.1.0",
		"@wordpress/icons": "^13.1.0",
		"@wordpress/prettier-config": "^4.45.0",
		"@wordpress/scripts": "^32.1.0",
		"@wordpress/stylelint-config": "^23.37.0",
		"cross-env": "^10.1.0",
		"eslint-plugin-jest": "^29.15.2",
		"jest-watch-typeahead": "^2.2.2",
		"lefthook": "^2.1.6",
		"lint-staged": "^16.4.0",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.15",
		"postcss-loader": "^8.2.1",
		"prettier": "npm:wp-prettier@^3",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"overrides": {
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"@wordpress/env": "^11.5.0",
		"fast-xml-parser": ">5.3.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"webpack-dev-server": ">=5.2.1"
	}
}
