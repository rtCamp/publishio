{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	// Point this to your TS ruleset.
	"extends": "./tsconfig.base.json",

	// Project-specific config.
	"compilerOptions": {
		"noEmit": true,
		"rootDir": ".",
		"outDir": "./build",
		"paths": {
			"@/*": [ "./src/*" ]
		},
		"types": [ "jest", "node" ]
	},
	"include": [
		"**/*.cjs",
		"**/*.mjs",
		"**/*.ts",
		"**/*.tsx",
		"**/*.json",
		"tests/**/*.ts",
		"tests/**/*.tsx"
	],
	"exclude": [
		"**/build/*",
		"**/build-apps/*",
		"vendor/*",
		"node_modules/*",
		"eslint.config.mjs"
	]
}
